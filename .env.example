APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

LLM_PROVIDER=openai_compatible
LLM_API_KEY=sk-...
LLM_BASE_URL=
LLM_MODEL=gpt-5-mini
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.1
DSPY_ENABLED=false
DSPY_MODEL=
DSPY_PROGRAM_DIR=artifacts/dspy
DSPY_TELEPROMPTER=MIPROv2
DSPY_FALLBACK_TO_RAW=true
CALENDLY_API_BASE_URL=https://api.calendly.com
CALENDLY_API_TOKEN=
CALENDLY_ORGANIZATION_URI=
CALENDLY_SCHEDULING_URL=
CALENDLY_EVENT_TYPE_URI=
CALENDLY_VALIDATION_PAGE_SIZE=20
TRACE_CAPTURE_ENABLED=false
TRACE_CAPTURE_DATABASE_URL=
TRACE_CAPTURE_QUEUE_SIZE=500
TRACE_CAPTURE_BATCH_SIZE=25
TRACE_CAPTURE_FLUSH_INTERVAL_MS=1000

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=
OPENAI_TIMEOUT_SECONDS=

COMPANY_CONFIG_PATH=config/company.json

MEMORY_BACKEND=langgraph_postgres
MEMORY_DATABASE_URL=
CHECKPOINT_DATABASE_URL=

QDRANT_ENABLED=false
QDRANT_SIMULATE=true
QDRANT_BASE_URL=
QDRANT_API_KEY=
